    41|    41|<script>
    42|    42|// ── XSS Sanitizer (PHMP v1 — 2026-04-24) ──
    43|    43|// Lightweight HTML sanitizer for API data rendered via innerHTML.
    44|    44|// Strips script tags, event handlers, and dangerous protocols.
    45|    45|window.sanitizeHTML = function(str) {
    46|    46|if (typeof str !== 'string') return str;
    47|    47|return str
    48|    48|.replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '')
    49|    49|.replace(/on\w+\s*=\s*["'][^"']*["']/gi, '')
    50|    50|.replace(/on\w+\s*=\s*[^\s>]*/gi, '')
    51|    51|.replace(/javascript\s*:/gi, '')
    52|    52|.replace(/data\s*:\s*text\/html/gi, '');
    53|    53|};
    54|    54|// PHASE 25.3 — GLOBAL VERSION LOCK (Read from version_config.js at runtime)
    55|    55|window.__APP_VERSION = window.__APP_VERSION || 
    56|    56|  (window.VERSION_CONFIG && window.VERSION_CONFIG.version) || 
    57|    57|  (window.GAS_CONFIG && window.GAS_CONFIG.version) || 
    58|    58|  'v5.17.0-phase42';
    59|    59|// Cache invalidation on version mismatch
    60|    60|if (localStorage.__APP_VERSION !== window.__APP_VERSION) {
    61|    61|console.warn('[VERSION] Dashboard version mismatch - clearing runtime caches only...');
    62|    62|if ('caches' in window) {
    63|    63|caches.keys().then(keys => keys.forEach(k => caches.delete(k)));
    64|    64|}
    65|    65|localStorage.__APP_VERSION = window.__APP_VERSION;
    66|    66|}
    67|    67|// PHASE 26.6 FIX: Minimal APP stub for error_boundary.js
    68|    68|window.APP = window.APP || { currentPage: 'dashboard_pc', user: null };
    69|    69|</script>
