     8|     8|<script>
     9|     9|// Session contract: accept success/valid and handle offline
    10|    10|if (typeof window.comphone_auth_session !== 'undefined') {
    11|    11|  // Session valid or offline - preserve local session
    12|    12|  var sessionData = localStorage.getItem('comphone_auth_session');
    13|    13|  if (sessionData) {
    14|    14|    try {
    15|    15|      var res = JSON.parse(sessionData);
    16|    16|      if (res._errorKind === 'offline' || res.valid || res.success) {
    17|    17|        // Session valid or offline - preserve local session
    18|    18|        if (res.valid || res.success) {
    19|    19|          localStorage.setItem('comphone_auth_session', JSON.stringify(res));
    20|    20|        }
    21|    21|      }
    22|    22|    } catch(e) {
    23|    23|      console.warn('[Session] Error parsing session data:', e);
    24|    24|    }
    25|    25|  }
    26|    26|}
    27|    27|</script>
