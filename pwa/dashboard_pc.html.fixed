    74|    74|<style>
    75|    75|:root {
    76|    76|--sidebar-w: 240px;
    77|    77|--header-h: 60px;
    78|    78|/* Local tokens bridged to shared design system (dashboard_shared.css) */
    79|    79|--blue: var(--cp-blue);
    80|    80|--green: var(--cp-green);
    81|    81|--amber: var(--cp-orange);
    82|    82|--red: var(--cp-red);
    83|    83|--gray: var(--cp-text2);
    84|    84|--bg: var(--cp-bg);
    85|    85|--card: var(--cp-card-bg);
    86|    86|--border: var(--cp-border);
    87|    87|}
    88|    88|* { box-sizing: border-box; margin: 0; padding: 0; }
    89|    89|body { font-family: 'Segoe UI','Sarabun',sans-serif; background: var(--bg); color: #111827; }
    90|    90|/* PHASE 25.5 — VERSION BADGE */
    91|    91|#version_badge {
    92|    92|position: fixed;
    93|    93|bottom: 12px;
    94|    94|right: 12px;
    95|    95|z-index: 9999;
    96|    96|background: rgba(15, 23, 42, 0.9);
    97|    97|color: #e2e8f0;
    98|    98|padding: 6px 12px;
    99|    99|border-radius: 6px;
   100|   100|font-size: 11px;
   101|   101|font-family: 'Segoe UI', monospace;
   102|   102|letter-spacing: 0.3px;
   103|   103|box-shadow: 0 2px 8px rgba(0,0,0,0.3);
   104|   104|backdrop-filter: blur(4px);
   105|   105|border: 1px solid rgba(255,255,255,0.08);
   106|   106|pointer-events: none;
   107|   107|transition: opacity 0.3s;
   108|   108|}
   109|   109|#version_badge .ok { color: #34d399; }
   110|   110|#version_badge .warn { color: #fbbf24; }
   111|   111|#version_badge .err { color: #f87171; }
   112|   112|/* ===== SIDEBAR ===== */
   113|   113|.sidebar {
   114|   114|position: fixed; left: 0; top: 0; bottom: 0;
   115|   115|width: var(--sidebar-w);
   116|   116|background:
   117|   117|  radial-gradient(circle at 20% 10%, rgba(59, 130, 246, 0.18) 0%, transparent 50%),
   118|   118|  linear-gradient(180deg, #0b1220 0%, #0f172a 100%);
   119|   119|color: #fff; z-index: 100; display: flex; flex-direction: column;
   120|   120|transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
   121|   121|box-shadow: 4px 0 24px rgba(15, 23, 42, 0.12);
   122|   122|border-right: 1px solid rgba(255, 255, 255, 0.06);
   123|   123|}
   124|   124|.sidebar-logo {
   125|   125|padding: 18px 20px 14px;
   126|   126|border-bottom: 1px solid rgba(255,255,255,0.08);
   127|   127|display: flex; align-items: center; gap: 12px;
   128|   128|}
   129|   129|.sidebar-logo .logo-icon {
   130|   130|width: 40px; height: 40px; border-radius: 10px;
   131|   131|background: linear-gradient(135deg, #3b82f6, #1d4ed8);
   132|   132|display: flex; align-items: center; justify-content: center;
   133|   133|font-size: 20px; flex-shrink: 0;
   134|   134|}
   135|   135|.sidebar-logo .logo-text { font-size: 15px; font-weight: 800; line-height: 1.2; }
   136|   136|.sidebar-logo .logo-sub { font-size: 10px; opacity: 0.5; font-weight: 400; }
   137|   137|.nav-section { padding: 12px 12px 4px; font-size: 10px; font-weight: 700; opacity: 0.4; text-transform: uppercase; letter-spacing: 1px; }
   138|   138|.nav-item {
   139|   139|display: flex; align-items: center; gap: 12px;
   140|   140|padding: 10px 16px; margin: 2px 8px; border-radius: 10px;
   141|   141|cursor: pointer; font-size: 14px; font-weight: 500;
   142|   142|color: rgba(255,255,255,0.65);
   143|   143|transition: var(--cp-transition-smooth, all 0.3s cubic-bezier(0.4, 0, 0.2, 1));
   144|   144|text-decoration: none;
   145|   145|}
   146|   146|.nav-item:hover {
   147|   147|background: rgba(255,255,255,0.08); color: #fff;
   148|   148|transform: translateX(2px);
   149|   149|}
   150|   150|.nav-item.active {
   151|   151|background: linear-gradient(135deg, #2563eb, #0ea5e9);
   152|   152|color: #fff; font-weight: 700;
   153|   153|box-shadow: 0 10px 26px rgba(37, 99, 235, 0.28);
   154|   154|}
   155|   155|.nav-item i { font-size: 16px; width: 20px; text-align: center; flex-shrink: 0; }
   156|   156|.nav-badge { margin-left: auto; background: #ef4444; color: #fff; border-radius: 20px; padding: 1px 7px; font-size: 10px; font-weight: 700; }
   157|   157|.sidebar-footer {
   158|   158|margin-top: auto; padding: 16px;
   159|   159|border-top: 1px solid rgba(255,255,255,0.08);
   160|   160|}
   161|   161|.user-chip {
   162|   162|display: flex; align-items: center; gap: 10px;
   163|   163|background: rgba(255,255,255,0.06); border-radius: 10px; padding: 10px 12px;
   164|   164|}
   165|   165|.user-avatar-sm {
   166|   166|width: 34px; height: 34px; border-radius: 50%;
   167|   167|background: linear-gradient(135deg, #3b82f6, #8b5cf6);
   168|   168|display: flex; align-items: center; justify-content: center;
   169|   169|font-weight: 800; font-size: 14px; color: #fff; flex-shrink: 0;
   170|   170|}
   171|   171|.user-name-sm { font-size: 13px; font-weight: 700; color: #fff; }
   172|   172|.user-role-sm { font-size: 10px; opacity: 0.5; }
   173|   173|/* ===== MAIN AREA ===== */
   174|   174|.main-area {
   175|   175|margin-left: var(--sidebar-w);
   176|   176|min-height: 100vh;
   177|   177|display: flex; flex-direction: column;
   178|   178|}
   179|   179|/* ===== TOPBAR ===== */
   180|   180|.topbar {
   181|   181|height: var(--header-h);
   182|   182|background: var(--cp-glass-bg, rgba(255, 255, 255, 0.85));
   183|   183|border-bottom: 1px solid var(--cp-glass-border, rgba(255, 255, 255, 0.3));
   184|   184|display: flex; align-items: center; gap: 16px;
   185|   185|padding: 0 24px; position: sticky; top: 0; z-index: 50;
   186|   186|backdrop-filter: var(--cp-glass-blur, blur(16px));
   187|   187|-webkit-backdrop-filter: var(--cp-glass-blur, blur(16px));
   188|   188|box-shadow: var(--cp-spatial-depth-1, 0 2px 8px rgba(0, 0, 0, 0.04));
   189|   189|}
   190|   190|.topbar-title { font-size: 18px; font-weight: 800; color: #111827; flex: 1; }
   191|   191|.topbar-date { font-size: 12px; color: var(--gray); }
   192|   192|.btn-refresh {
   193|   193|background: var(--cp-glass-bg, rgba(255, 255, 255, 0.65));
   194|   194|backdrop-filter: var(--cp-glass-blur, blur(16px));
   195|   195|-webkit-backdrop-filter: var(--cp-glass-blur, blur(16px));
   196|   196|border: 1px solid var(--cp-glass-border, rgba(255, 255, 255, 0.3));
   197|   197|border-radius: 8px; padding: 7px 14px; font-size: 13px;
   198|   198|color: #374151; cursor: pointer; display: flex; align-items: center; gap: 6px;
   199|   199|transition: var(--cp-transition-smooth, all 0.3s cubic-bezier(0.4, 0, 0.2, 1));
   200|   200|position: relative; overflow: hidden;
   201|   201|}
   202|   202|.btn-refresh:hover {
   203|   203|background: #e2e8f0;
   204|   204|box-shadow: var(--cp-spatial-depth-2, 0 4px 16px rgba(0, 0, 0, 0.08));
   205|   205|transform: translateY(-1px);
   206|   206|}
   207|   207|.btn-pwa {
   208|   208|background: var(--cp-gradient-border, linear-gradient(135deg, #00d4ff, #a855f7));
   209|   209|color: #fff; border: none;
   210|   210|border-radius: 8px; padding: 7px 14px; font-size: 13px;
   211|   211|cursor: pointer; display: flex; align-items: center; gap: 6px;
   212|   212|text-decoration: none;
   213|   213|transition: var(--cp-transition-smooth, all 0.3s cubic-bezier(0.4, 0, 0.2, 1));
   214|   214|position: relative; overflow: hidden;
   215|   215|}
   216|   216|.btn-pwa:hover {
   217|   217|transform: translateY(-1px);
   218|   218|box-shadow: var(--cp-spatial-depth-2, 0 4px 16px rgba(0, 0, 0, 0.08));
   219|   219|filter: brightness(1.1);
   220|   220|}
   221|   221|/* ===== CONTENT ===== */
   222|   222|.content { padding: 24px; flex: 1; }
   223|   223|/* ===== KPI ROW ===== */
   224|   224|.kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 20px; }
   225|   225|.kpi-box {
   226|   226|background: var(--cp-glass-bg, rgba(255, 255, 255, 0.65));
   227|   227|backdrop-filter: var(--cp-glass-blur, blur(16px));
   228|   228|-webkit-backdrop-filter: var(--cp-glass-blur, blur(16px));
   229|   229|border: 1px solid var(--cp-glass-border, rgba(255, 255, 255, 0.3));
   230|   230|border-radius: 16px; padding: 20px;
   231|   231|display: flex; align-items: center; gap: 16px;
   232|   232|box-shadow: var(--cp-glass-shadow, 0 8px 32px rgba(0, 0, 0, 0.08));
   233|   233|transition: var(--cp-transition-smooth, all 0.3s cubic-bezier(0.4, 0, 0.2, 1));
   234|   234|position: relative; overflow: hidden;
   235|   235|}
   236|   236|.kpi-box::before {
   237|   237|content: ''; position: absolute; top: 0; left: 0; right: 0;
   238|   238|height: 3px; background: var(--cp-gradient-border, linear-gradient(135deg, #00d4ff, #a855f7));
   239|   239|opacity: 0; transition: opacity 0.2s;
   240|   240|}
   241|   241|.kpi-box:hover { transform: translateY(-4px); box-shadow: var(--cp-spatial-depth-3, 0 8px 32px rgba(0, 0, 0, 0.12)); border-color: #bfdbfe; }
   242|   242|.kpi-box:hover::before { opacity: 1; }
   243|   243|.kpi-icon-box {
   244|   244|width: 52px; height: 52px; border-radius: 14px;
   245|   245|display: flex; align-items: center; justify-content: center;
   246|   246|font-size: 22px; flex-shrink: 0;
   247|   247|}
   248|   248|.kpi-num { font-size: 28px; font-weight: 900; line-height: 1; }
   249|   249|.kpi-lbl { font-size: 12px; color: var(--gray); margin-top: 3px; font-weight: 600; }
   250|   250|.kpi-sub { font-size: 11px; color: var(--gray); margin-top: 2px; }
   251|   251|.kpi-alert-pulse { animation: kpi-pulse 1.5s ease-in-out infinite; border: 2px solid #fca5a5; }
   252|   252|@keyframes kpi-pulse {
   253|   253|0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.3); }
   254|   254|50% { box-shadow: 0 0 0 8px rgba(239,68,68,0); }
   255|   255|}
   256|   256|/* ===== GRID 2 COL ===== */
   257|   257|.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
   258|   258|.grid-3 { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 20px; }
   259|   259|/* ===== CARD ===== */
   260|   260|.card-box {
   261|   261|background: var(--cp-glass-bg, rgba(255, 255, 255, 0.65));
   262|   262|backdrop-filter: var(--cp-glass-blur, blur(16px));
   263|   263|-webkit-backdrop-filter: var(--cp-glass-blur, blur(16px));
   264|   264|border: 1px solid var(--cp-glass-border, rgba(255, 255, 255, 0.3));
   265|   265|border-radius: 14px; padding: 20px;
   266|   266|box-shadow: var(--cp-glass-shadow, 0 8px 32px rgba(0, 0, 0, 0.08));
   267|   267|transition: var(--cp-transition-smooth, all 0.3s cubic-bezier(0.4, 0, 0.2, 1));
   268|   268|}
   269|   269|.card-box:hover {
   270|   270|box-shadow: var(--cp-spatial-depth-3, 0 8px 32px rgba(0, 0, 0, 0.12));
   271|   271|transform: translateY(-2px);
   272|   272|}
   273|   273|.card-title {
   274|   274|font-size: 14px; font-weight: 800; color: #111827;
   275|   275|margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
   276|   276|}
   277|   277|.card-title .badge-count {
   278|   278|background: #f1f5f9; color: var(--gray);
   279|   279|border-radius: 20px; padding: 2px 8px; font-size: 11px; font-weight: 700;
   280|   280|}
   281|   281|/* ===== JOB TABLE ===== */
   282|   282|.job-table { width: 100%; border-collapse: collapse; font-size: 13px; }
   283|   283|.job-table th {
   284|   284|text-align: left; padding: 8px 12px;
   285|   285|font-size: 11px; font-weight: 700; color: var(--gray);
   286|   286|border-bottom: 2px solid var(--border);
   287|   287|background: #f8fafc;
   288|   288|}
   289|   289|.job-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
   290|   290|.job-table tr:last-child td { border-bottom: none; }
   291|   291|.job-table tr:hover td { background: #f8fafc; }
   292|   292|.job-table .job-id { font-weight: 700; color: var(--blue); font-size: 12px; }
   293|   293|.job-table .customer { font-weight: 600; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
   294|   294|.job-table .symptom { color: var(--gray); max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
   295|   295|.status-badge {
   296|   296|display: inline-block; padding: 3px 10px; border-radius: 20px;
   297|   297|font-size: 11px; font-weight: 700; white-space: nowrap;
   298|   298|}
   299|   299|.days-badge {
   300|   300|display: inline-block; padding: 2px 8px; border-radius: 6px;
   301|   301|font-size: 11px; font-weight: 700;
   302|   302|}
   303|   303|/* ===== STATUS DIST ===== */
   304|   304|.status-dist { display: flex; flex-direction: column; gap: 10px; }
   305|   305|.status-row { display: flex; align-items: center; gap: 10px; }
   306|   306|.status-label { font-size: 12px; font-weight: 600; width: 120px; flex-shrink: 0; }
   307|   307|.status-bar-wrap { flex: 1; background: #f1f5f9; border-radius: 6px; height: 8px; overflow: hidden; }
   308|   308|.status-bar { height: 100%; border-radius: 6px; transition: width 0.5s; }
   309|   309|.status-count { font-size: 12px; font-weight: 700; width: 30px; text-align: right; flex-shrink: 0; }
   310|   310|/* ===== ALERTS ===== */
   311|   311|.alert-row {
   312|   312|display: flex; align-items: flex-start; gap: 12px;
   313|   313|padding: 10px 0; border-bottom: 1px solid var(--border);
   314|   314|}
   315|   315|.alert-row:last-child { border-bottom: none; }
   316|   316|.alert-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
   317|   317|.alert-msg { font-size: 13px; font-weight: 700; }
   318|   318|.alert-sub { font-size: 11px; color: var(--gray); margin-top: 2px; }
   319|   319|/* ===== CHART ===== */
   320|   320|.chart-wrap { position: relative; height: 220px; }
   321|   321|/* ===== LOADING ===== */
   322|   322|.loading-state { text-align: center; padding: 60px 20px; color: var(--gray); }
   323|   323|.spinner-pc {
   324|   324|width: 40px; height: 40px; border: 3px solid #e2e8f0;
   325|   325|border-top-color: #3b82f6; border-radius: 50%;
   326|   326|animation: spin 0.8s linear infinite; margin: 0 auto 16px;
   327|   327|}
   328|   328|@keyframes spin { to { transform: rotate(360deg); } }
   329|   329|/* ===== RESPONSIVE ===== */
   330|   330|@media (max-width: 1200px) {
   331|   331|.kpi-row { grid-template-columns: repeat(2, 1fr); }
   332|   332|.grid-3 { grid-template-columns: 1fr 1fr; }
   333|   333|}
   334|   334|@media (max-width: 900px) {
   335|   335|.sidebar { width: 64px; }
   336|   336|.sidebar-logo .logo-text, .sidebar-logo .logo-sub,
   337|   337|.nav-item span, .nav-section, .user-name-sm, .user-role-sm { display: none; }
   338|   338|.nav-item { justify-content: center; padding: 12px; }
   339|   339|.nav-item i { width: auto; }
   340|   340|.main-area { margin-left: 64px; }
   341|   341|.grid-2, .grid-3 { grid-template-columns: 1fr; }
   342|   342|.kpi-row { grid-template-columns: repeat(2, 1fr); }
   343|   343|}
   344|   344|@media (max-width: 600px) {
   345|   345|.kpi-row { grid-template-columns: 1fr 1fr; }
   346|   346|.content { padding: 12px; }
   347|   347|}
   348|   348|/* ===== LOGIN OVERLAY ===== */
   349|   349|#login-overlay {
   350|   350|position: fixed; inset: 0; z-index: 99999;
   351|   351|background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
   352|   352|display: flex; align-items: center; justify-content: center;
   353|   353|font-family: 'Inter', sans-serif;
   354|   354|}
   355|   355|#login-overlay .login-card {
   356|   356|background: var(--cp-glass-bg, rgba(255, 255, 255, 0.65));
   357|   357|backdrop-filter: var(--cp-glass-blur, blur(16px));
   358|   358|-webkit-backdrop-filter: var(--cp-glass-blur, blur(16px));
   359|   359|border: 1px solid var(--cp-glass-border, rgba(255, 255, 255, 0.3));
   360|   360|border-radius: 20px; padding: 40px 36px;
   361|   361|width: 100%; max-width: 380px;
   362|   362|box-shadow: var(--cp-spatial-depth-3, 0 8px 32px rgba(0, 0, 0, 0.12));
   363|   363|text-align: center;
   364|   364|}
   365|   365|#login-overlay .login-logo { font-size: 40px; margin-bottom: 8px; }
   366|   366|#login-overlay .login-title { font-size: 20px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
   367|   367|#login-overlay .login-sub { font-size: 12px; color: #94a3b8; margin-bottom: 28px; }
   368|   368|#login-overlay .login-field {
   369|   369|width: 100%; padding: 12px 16px; border: 1.5px solid #e2e8f0; border-radius: 10px;
   370|   370|font-size: 14px; margin-bottom: 12px; outline: none; transition: border 0.2s;
   371|   371|box-sizing: border-box;
   372|   372|}
   373|   373|#login-overlay .login-field:focus { border-color: #3b82f6; }
   374|   374|#login-overlay .login-btn {
   375|   375|width: 100%; padding: 13px; background: #3b82f6; color: #fff; border: none;
   376|   376|border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer;
   377|   377|transition: background 0.2s; margin-top: 4px;
   378|   378|}
   379|   379|#login-overlay .login-btn:hover { background: #2563eb; }
   380|   380|#login-overlay .login-btn:disabled { background: #94a3b8; cursor: wait; }
   381|   381|#login-overlay .login-error {
   382|   382|color: #ef4444; font-size: 13px; margin-top: 10px; min-height: 20px;
   383|   383|}
   384|   384|</style>
   385|   385|</head>
