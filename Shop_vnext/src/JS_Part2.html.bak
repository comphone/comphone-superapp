<script>
var CURRENT_JOB_ID=null;

function viewJob(id){
  var j=findJob(id);
  if(!j){toast('❌ ไม่พบงาน '+id,'er');return}
  CURRENT_JOB_ID=id;
  var fu=j.folder?j.folder:'https://drive.google.com/drive/folders/1YRZRG9r1Y_jMHg2XFFKYjK4Hx-sW0Eq0';
  var h='<h2>📋 '+esc(j.id)+'</h2>';
  h+='<div class="modal-subtitle">'+esc(j.customer)+'</div>';
  h+='<div style="font-size:16px;color:var(--t2);line-height:2;margin-bottom:18px">';
  h+='📌 '+esc(j.symptom||'-')+'<br>';
  h+='📝 '+sBadge(j.status)+' '+esc(j.status)+'<br>';
  h+='🔧 '+esc(j.tech||'-')+'<br>';
  h+='⏰ '+(j.created||'-');
  h+='</div>';
  h+='<div class="d-flex flex-wrap gap-2 mb-3">';
  h+='<button onclick="showStatusModal()" class="btn btn-blue btn-lg" style="padding:12px 20px;font-size:15px">📝 เปลี่ยนสถานะ</button>';
  h+='<button onclick="showPhotoUploadModal()" class="btn btn-success btn-lg" style="padding:12px 20px;font-size:15px">📷 เพิ่มรูปภาพ</button>';
  h+='<button onclick="openFolder(\''+fu.replace(/'/g,"\\'")+'\')" class="btn btn-lg" style="background:var(--purple);color:#fff">📁 อัลบ้มรูป</button>';
  h+='</div>';
  h+='<div class="mb-3">';
  h+='<label class="form-label-lg">📝 หมายเหตุด่วน</label>';
  h+='<textarea id="qnote" class="form-control dark-input" rows="3" placeholder="พิมพ์..." style="min-height:100px"></textarea>';
  h+='<button onclick="addQuickNote()" class="btn btn-green w-100 mt-2 btn-lg">📎 บันทึก</button>';
  h+='</div>';
  h+='<div class="mb-3">';
  h+='<label class="form-label-lg">📄 ประวัติ</label>';
  h+='<div id="jtl"></div>';
  h+='</div>';
  h+='<button onclick="showEditJobModal()" class="btn btn-outline-dark w-100 btn-lg mb-2">✏️ แก้ไข</button>';
  h+='<button onclick="closeModal()" class="btn btn-outline-dark w-100 btn-lg">✖ ปิด</button>';
  openModal(h);
  try{
    google.script.run.withSuccessHandler(function(r){
      var el=document.getElementById('jtl');
      if(!el)return;
      if(r&&r.timeline&&r.timeline.length>0){
        var x='';
        for(var i=0;i<Math.min(r.timeline.length,20);i++){
          var e=r.timeline[i];
          x+='<div class="timeline-item"><div class="ts">'+esc(e.ts)+'</div><div class="ta">'+esc(e.action)+'</div>';
          if(e.detail)x+='<div class="td">'+esc(e.detail)+'</div>';
          x+='</div>';
        }
        el.innerHTML=x;
      }else{
        el.innerHTML='<div class="empty-state" style="padding:16px">ยังไม่มีบันทึก</div>';
      }
    }).getJobTimeline(id);
  }catch(x){}
}

function openFolder(url){window.open(url,'_blank')}

function showStatusModal(){
  var j=findJob(CURRENT_JOB_ID);if(!j)return;
  var h='<h2>📝 เปลี่ยนสถานะ</h2>';
  h+='<div class="modal-subtitle">'+esc(CURRENT_JOB_ID)+' — '+esc(j.customer)+'</div>';
  h+='<div style="font-size:16px;color:var(--t2);margin-bottom:16px">ปัจจุบัน: <b>'+esc(j.status)+'</b></div>';
  h+='<div class="status-btn-grid">';
  h+="<button onclick=\"chgStat('รอดำเนินการ')\" class=\"btn btn-warn btn-lg\">⏳ รอดำเนินการ</button>";
  h+="<button onclick=\"chgStat('InProgress')\" class=\"btn btn-blue btn-lg\">🔄 กำลังดำเนินการ</button>";
  h+="<button onclick=\"chgStat('Completed')\" class=\"btn btn-green btn-lg\">✅ เสร็จแล้ว</button>";
  h+="<button onclick=\"chgStat('ยกเลิก')\" class=\"btn btn-err btn-lg\">❌ ยกเลิก</button>";
  h+='</div>';
  h+='<button onclick="closeModal()" class="btn btn-outline-dark w-100 btn-lg">ยกเลิก</button>';
  openModal(h);
}

function chgStat(s){
  if(!CURRENT_JOB_ID||!s)return;
  var bs=document.querySelectorAll('.status-btn-grid .btn');
  for(var i=0;i<bs.length;i++)bs[i].disabled=true;
  google.script.run.withSuccessHandler(function(){
    toast('✅ เปลี่ยน: '+s,'ok');closeModal();loadData();
  }).withFailureHandler(function(e){
    var b2=document.querySelectorAll('.status-btn-grid .btn');
    for(var i=0;i<b2.length;i++)b2[i].disabled=false;
    toast('❌ '+(e.message||e),'er');
  }).updateJobStatus({job_id:CURRENT_JOB_ID,status:s,note:'Dashboard'});
}

function showEditJobModal(){
  var j=findJob(CURRENT_JOB_ID);if(!j)return;
  var h='<h2>✏️ แก้ไข: '+esc(j.id)+'</h2>';
  h+='<div class="modal-subtitle">'+esc(j.customer)+'</div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">ชื่อลูกค้า</label>';
  h+='<input type="text" class="form-control dark-input" id="eName" value="'+esc(j.customer)+'"></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">อาการ</label>';
  h+='<textarea class="form-control dark-input" id="eSymp" rows="3" style="min-height:100px">'+esc(j.symptom||'')+'</textarea></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">ช่าง</label>';
  h+='<input type="text" class="form-control dark-input" id="eTech" value="'+esc(j.tech||'')+'"></div>';
  h+='<button onclick="saveEdit()" class="btn btn-green w-100 btn-lg">📎 บันทึก</button>';
  h+='<button onclick="closeModal()" class="btn btn-outline-dark w-100 btn-lg mt-2">ยกเลิก</button>';
  openModal(h);
}

function saveEdit(){
  var n=(document.getElementById('eName').value||'').trim();
  var s=(document.getElementById('eSymp').value||'').trim();
  var t=(document.getElementById('eTech').value||'').trim();
  if(!n){toast('❌ ชื่อลูกค้าห้ามว่าง','er');return}
  var b=document.querySelector('#modalContent .btn-green');
  setBtnLoading(b,true,'...บันทึก');
  google.script.run.withSuccessHandler(function(){
    toast('✅ แก้ไขแล้ว','ok');closeModal();loadData();
  }).withFailureHandler(function(e){
    setBtnLoading(b,false);toast('❌ '+(e.message||e),'er');
  }).updateJobById(CURRENT_JOB_ID,{name:n,symptom:s,tech:t});
}

function addQuickNote(){
  var n=document.getElementById('qnote');
  if(!n||!n.value.trim()){toast('❌ พิมพ์ก่อน','er');return}
  var b=document.querySelector('#modalContent .btn-green');
  setBtnLoading(b,true,'...บันทึก');
  google.script.run.withSuccessHandler(function(){
    toast('✅ บันทึกแล้ว','ok');closeModal();loadData();
  }).withFailureHandler(function(e){
    setBtnLoading(b,false);toast('❌ '+e.message,'er');
  }).addQuickNote(CURRENT_JOB_ID,n.value.trim(),'โหน่ง');
}

function openNewJobModal(){
  var h='<h2>➕ เปิดงานใหม่</h2>';
  h+='<div class="form-group-lg" style="margin-top:18px"><label class="form-label-lg">ชื่อลูกค้า *</label>';
  h+='<input type="text" class="form-control dark-input" id="oName" placeholder="ชื่อลูกค้า" style="font-size:18px"></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">เบอร์โทร</label>';
  h+='<input type="tel" class="form-control dark-input" id="oPhone" placeholder="08x-xxx-xxxx" style="font-size:18px"></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">อาการ *</label>';
  h+='<textarea class="form-control dark-input" id="oSyp" rows="3" placeholder="อาการเสีย..." style="min-height:120px;font-size:17px"></textarea></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">ช่างที่รับงาน</label>';
  h+='<input type="text" class="form-control dark-input" id="oTech" placeholder="ช่าง" style="font-size:18px"></div>';
  h+='<button onclick="doOpen()" class="btn btn-green w-100 btn-lg" style="font-size:18px;padding:16px">🚀 เปิดงาน</button>';
  h+='<button onclick="closeModal()" class="btn btn-outline-dark w-100 btn-lg mt-2">ยกเลิก</button>';
  openModal(h);
}

function doOpen(){
  var n=(document.getElementById('oName').value||'').trim();
  var p=(document.getElementById('oPhone').value||'').trim();
  var s=(document.getElementById('oSyp').value||'').trim();
  var t=(document.getElementById('oTech').value||'').trim();
  if(!n){toast('❌ ใส่ชื่อลูกค้า','er');return}
  if(!s){toast('❌ ใส่อาการ','er');return}
  var b=document.querySelector('#modalContent .btn-green');
  setBtnLoading(b,true,'...เปิดงาน');
  google.script.run.withSuccessHandler(function(r){
    var jid=(r&&r.job_id)?r.job_id:'?';
    toast('🎉 เปิดงาน '+jid+' สำเร็จ','ok');closeModal();loadData();
  }).withFailureHandler(function(e){
    setBtnLoading(b,false);toast('❌ '+(e.message||e),'er');
  }).openJob({name:n,phone:p,symptom:s,tech:t});
}

function showNoteModal(){
  var h='<h2>📝 หมายเหตุ</h2>';
  h+='<div class="form-group-lg" style="margin-top:18px"><label class="form-label-lg">Job ID</label>';
  h+='<input type="text" class="form-control dark-input" id="gNid" placeholder="เช่น J0001" style="font-size:18px"></div>';
  h+='<div class="form-group-lg"><label class="form-label-lg">ข้อความ</label>';
  h+='<textarea class="form-control dark-input" id="gNtx" rows="4" placeholder="พิมพ์..." style="min-height:140px;font-size:17px"></textarea></div>';
  h+='<button onclick="saveGNote()" class="btn btn-green w-100 btn-lg">📎 บันทึก</button>';
  h+='<button onclick="closeModal()" class="btn btn-outline-dark w-100 btn-lg mt-2">ยกเลิก</button>';
  openModal(h);
}

function saveGNote(){
  var id=(document.getElementById('gNid').value||'').trim();
  var n=(document.getElementById('gNtx').value||'').trim();
  if(!id){toast('❌ ใส่ Job ID','er');return}
  if(!n){toast('❌ ใส่ข้อความ','er');return}
  var b=document.querySelector('#modalContent .btn-green');
  setBtnLoading(b,true,'...บันทึก');
  google.script.run.withSuccessHandler(function(){
    toast('✅ บันทึกแล้ว','ok');closeModal();loadData();
  }).withFailureHandler(function(e){
    setBtnLoading(b,false);toast('❌ '+(e.message||e),'er');
  }).addQuickNote(id,n,'โหน่ง');
}

function sendSummary(){
  try{
    showLoading();
    google.script.run.withSuccessHandler(function(r){
      hideLoading();
      if(r&&r.success)toast('✅ ส่ง LINE สำเร็จ','ok');
      else toast('❌ '+JSON.stringify(r),'er');
      loadData();
    }).withFailureHandler(function(e){
      hideLoading();toast('❌ '+(e.message||e),'er');
    }).sendDashboardSummary();
  }catch(x){toast('Error: '+x.message,'er')}
}

function processPhotos(){
  if(!confirm('เริ่มจัดรูปทั้งหมด?'))return;
  showLoading();
  google.script.run.withSuccessHandler(function(r){
    hideLoading();
    if(r)toast('✅ จัดรูป สำเร็จ '+(r.successful||0)+' | ผิด '+(r.failed||0),'ok');
    else toast('✅ เรียบร้อย','ok');
    loadData();
  }).withFailureHandler(function(e){
    hideLoading();toast('❌ '+(e.message||e),'er');
  }).processImageSorting();
}
console.log('✅ V366 Part2 loaded');
</script>
